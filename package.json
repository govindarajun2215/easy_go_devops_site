
// Node 20+ ESM script: fetch YouTube RSS and write public/videos.json
import fs from 'node:fs/promises';
import path from 'node:path';
import { fileURLToPath } from 'node:url';
import https from 'node:https';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const channelId = process.env.CHANNEL_ID;
if (!channelId) {
  console.error("CHANNEL_ID env var is required");
  process.exit(0); // don't fail the build
}

const rssUrl = `https://www.youtube.com/feeds/videos.xml?channel_id=${encodeURIComponent(channelId)}`;

function fetchText(url) {
  return new Promise((resolve, reject) => {
    https.get(url, (res) => {
      if (res.statusCode !== 200) return reject(new Error(`HTTP ${res.statusCode}`));
      let data = '';
      res.on('data', chunk => data += chunk);
      res.on('end', () => resolve(data));
    }).on('error', reject);
  });
}

function xmlExtractEntries(xml) {
  // Very small XML parser for the fields we need, to avoid extra deps
  const entriesRaw = xml.split('<entry>').slice(1).map(e => e.split('</entry>')[0]);
  const get = (s, tag) => {
    const m = s.match(new RegExp(`<${tag}[^>]*>([\s\S]*?)</${tag}>`));
    return m ? m[1].trim() : '';
  };
  const getAttr = (s, tag, attr) => {
    const m = s.match(new RegExp(`<${tag}[^>]*${attr}="([^"]+)"`));
    return m ? m[1] : '';
  };
  return entriesRaw.map(e => {
    const title = get(e, 'title');
    const link = getAttr(e, 'link', 'href');
    const videoId = get(e, 'yt:videoId');
    const published = get(e, 'published');
    const thumb = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
    return {
      title,
      url: link || `https://www.youtube.com/watch?v=${videoId}`,
      videoId,
      thumbnail: thumb,
      publishedAt: published
    };
  });
}

try {
  const xml = await fetchText(rssUrl);
  const items = xmlExtractEntries(xml).slice(0, 12); // latest 12
  const out = { items, generatedAt: new Date().toISOString() };
  const outPath = path.join(__dirname, '..', 'public', 'videos.json');
  await fs.writeFile(outPath, JSON.stringify(out, null, 2), 'utf8');
  console.log(`Wrote ${out.items.length} items to public/videos.json`);
} catch (err) {
  console.error(`RSS build failed: ${err.message}`);
  // do not fail CI; leave previous videos.json if present
  process.exit(0);
}
